<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Oxagon — Tenant SLA Report — {{ m.tenant_id }} — {{ m.month }}</title>
  <style>
    body { font-family: "Helvetica Neue", Arial, sans-serif; color: #111; }
    header { border-bottom: 2px solid #0b1220; padding-bottom: 12px; margin-bottom: 24px; }
    h1 { margin: 0; color: #0b1220; }
    .kpi-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .kpi { padding: 16px; border-radius: 8px; background: #f4f6fb; }
    .kpi-label { font-size: 11px; text-transform: uppercase; color: #5a6473; }
    .kpi-value { font-size: 28px; font-weight: 700; color: #0b1220; }
    footer { margin-top: 48px; font-size: 11px; color: #5a6473; }
  </style>
</head>
<body>
  <header>
    <h1>Oxagon Port — Tenant SLA Report</h1>
    <p>{{ m.tenant_id }} &middot; {{ m.month }}</p>
  </header>

  <section class="kpi-grid">
    <div class="kpi">
      <div class="kpi-label">Containers (gate-out this month)</div>
      <div class="kpi-value">{{ "{:,}".format(m.container_count) }}</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Avg dwell (hours)</div>
      <div class="kpi-value">{{ "%.1f"|format(m.avg_dwell_hours) }}</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">P95 dwell (hours)</div>
      <div class="kpi-value">{{ "%.1f"|format(m.p95_dwell_hours) }}</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Customs P95 lead (hours)</div>
      <div class="kpi-value">{{ "%.1f"|format(m.customs_p95_lead_hours) }}</div>
    </div>
  </section>

  <footer>
    Live dashboard: <a href="{{ m.looker_dashboard_url }}">{{ m.looker_dashboard_url }}</a><br>
    Generated by tenant-reports (KAN-37). Questions: oxagon-platform@neom.com
  </footer>
</body>
</html>
